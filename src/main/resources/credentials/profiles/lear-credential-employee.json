{
  "credential_configuration_id": "LEARCredentialEmployee",
  "credential_format": "dc+sd-jwt",
  "scope": "lear_credential_employee_sd_jwt",

  "credential_definition": {
    "context": [
      "https://www.w3.org/ns/credentials/v2",
      "https://credentials.eudistack.eu/.well-known/credentials/lear_credential_employee/w3c/v3"
    ],
    "type": ["VerifiableCredential", "LEARCredentialEmployee"]
  },

  "cryptographic_binding_methods_supported": ["did:key"],
  "credential_signing_alg_values_supported": ["ES256"],
  "proof_types_supported": {
    "jwt": {
      "proof_signing_alg_values_supported": ["ES256"]
    }
  },

  "credential_metadata": {
    "display": [
      {
        "name": "LEAR Credential Employee",
        "locale": "en",
        "description": "Verifiable Credential for employees of an organization"
      }
    ],
    "claims": [
      {
        "path": ["mandate", "mandatee", "firstName"],
        "display": [{ "name": "First Name", "locale": "en" }]
      },
      {
        "path": ["mandate", "mandatee", "lastName"],
        "display": [{ "name": "Last Name", "locale": "en" }]
      },
      {
        "path": ["mandate", "mandatee", "email"],
        "display": [{ "name": "Email", "locale": "en" }]
      },
      {
        "path": ["mandate", "mandator", "organizationIdentifier"],
        "display": [{ "name": "Organization", "locale": "en" }]
      },
      {
        "path": ["mandate", "power"],
        "display": [{ "name": "Powers", "locale": "en" }]
      }
    ]
  },

  "validity_days": 365,
  "issuer_type": "DETAILED",
  "cnf_required": true,
  "description": "Verifiable Credential for employees of an organization",

  "subject_extraction": {
    "strategy": "concat",
    "fields": ["mandate.mandatee.firstName", "mandate.mandatee.lastName"],
    "separator": " "
  },
  "organization_extraction": {
    "strategy": "field",
    "field": "mandate.mandator.organizationIdentifier"
  },

  "sd_jwt": {
    "vct": "eu.europa.ec.eudi.lce.1",
    "sd_alg": "sha-256",
    "sd_claims": ["mandate"]
  }
}
