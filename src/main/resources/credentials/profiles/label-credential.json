{
  "credential_configuration_id": "gx:LabelCredential",
  "format": "jwt_vc_json",
  "scope": "gx:LabelCredential",

  "credential_definition": {
    "context": [
      "https://www.w3.org/ns/credentials/v2",
      "https://w3id.org/gaia-x/development#"
    ],
    "type": ["gx:LabelCredential", "VerifiableCredential"]
  },

  "cryptographic_binding_methods_supported": [],
  "credential_signing_alg_values_supported": ["ES256"],
  "proof_types_supported": {},

  "credential_metadata": {
    "display": [
      {
        "name": "Label Credential",
        "locale": "en",
        "description": "Gaia-X Label Credential for compliance certification"
      }
    ],
    "claims": [
      {
        "path": ["credentialSubject", "gx:labelLevel"],
        "display": [{ "name": "Label Level", "locale": "en" }]
      },
      {
        "path": ["credentialSubject", "gx:engineVersion"],
        "display": [{ "name": "Engine Version", "locale": "en" }]
      },
      {
        "path": ["credentialSubject", "gx:rulesVersion"],
        "display": [{ "name": "Rules Version", "locale": "en" }]
      }
    ]
  },

  "validity_days": 0,
  "issuer_type": "SIMPLE",
  "cnf_required": false,
  "description": null,

  "subject_extraction": {
    "strategy": "field",
    "fields": ["credentialSubject.id"],
    "separator": null
  },
  "organization_extraction": {
    "strategy": "session",
    "field": null
  }
}
