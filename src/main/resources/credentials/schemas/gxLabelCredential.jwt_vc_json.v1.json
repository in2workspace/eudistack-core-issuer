{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gxLabelCredential.jwt_vc_json.v1",
  "title": "Gaia-X Label Credential (JWT VC JSON)",
  "description": "Input payload schema for the Gaia-X Label Credential",
  "type": "object",
  "required": ["credentialSubject", "validFrom", "validUntil"],
  "properties": {
    "@context": {
      "type": "array",
      "items": { "type": "string" }
    },
    "type": {
      "type": "array",
      "items": { "type": "string" },
      "contains": { "const": "gx:LabelCredential" }
    },
    "credentialSubject": {
      "type": "object",
      "required": ["gx:labelLevel", "gx:engineVersion", "gx:rulesVersion"],
      "properties": {
        "id": {
          "type": "string",
          "description": "DID of the subject (company being certified)"
        },
        "gx:labelLevel": {
          "type": "string",
          "description": "Gaia-X label level (e.g. L1, L2, L3)"
        },
        "gx:engineVersion": {
          "type": "string",
          "description": "Version of the compliance engine"
        },
        "gx:rulesVersion": {
          "type": "string",
          "description": "Version of the compliance rules applied"
        },
        "gx:compliantCredentials": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "type", "gx:digestSRI"],
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string" },
              "gx:digestSRI": { "type": "string" }
            }
          }
        },
        "gx:validatedCriteria": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "validFrom": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 validity start"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 validity end"
    }
  }
}
